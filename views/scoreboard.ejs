<%- include("partials/header", { title }) %>
<%- include("partials/navbar") %>

<main class="container py-4">

  <div class="d-flex justify-content-between align-items-center gap-3 mb-4">
    <div>
      <h1 class="page-title mb-1">Scoreboard</h1>
      <p class="text-muted mb-0">
        Family-wide rankings across Sneaky Witches, Sons of Witches, and Witch?! Please!
      </p>
    </div>
  </div>

  <div class="card clan-card">
    <div class="card-body">

      <div class="d-flex justify-content-between align-items-center mb-3 flex-wrap gap-3">

        <div class="btn-group btn-group-sm" role="group">
          <a
            href="/scoreboard?type=war"
            class="btn <%= type === 'war' ? 'btn-fw-primary' : 'btn-outline-light' %>">
            War Scoreboard
          </a>

          <a
            href="/scoreboard?type=leagues"
            class="btn <%= type === 'leagues' ? 'btn-fw-primary' : 'btn-outline-light' %>">
            Ranked Scoreboard
          </a>
        </div>

        <% if (type === "leagues") { %>
          <form method="GET" action="/scoreboard" class="d-flex gap-2 align-items-center">
            <input type="hidden" name="type" value="leagues">

            <select name="league" class="form-select form-select-sm scoreboard-select" onchange="this.form.submit()">
              <% leagueOptions.forEach(league => { %>
                <option
                  value="<%= league %>"
                  <%= league === selectedLeague ? "selected" : "" %>>
                  <%= league %>
                </option>
              <% }) %>
            </select>
          </form>
        <% } %>

      </div>

      <% if (type === "leagues") { %>

        <div class="d-flex justify-content-between align-items-center mb-3">
          <div>
            <h4 class="mb-0"><%= selectedLeague %></h4>
            <span class="text-muted small">
              <%= selectedLeagueGroup.members.length %> players
            </span>
          </div>
        </div>

        <div class="table-responsive">
          <table class="table table-dark table-hover align-middle mb-0">
            <thead>
              <tr>
                <th>Rank</th>
                <th>Player</th>
                <th>Clan</th>
                <th>League</th>
                <th>Trophies</th>
              </tr>
            </thead>

            <tbody>
              <% selectedLeagueGroup.members.forEach(member => { %>
                <tr>
                  <td><%= member.scoreboardRank %></td>

                  <td>
                    <div class="d-flex align-items-center gap-2">
                      <% if (member.leagueTier?.iconUrls?.small) { %>
                        <img
                          src="<%= member.leagueTier.iconUrls.small %>"
                          alt="<%= member.leagueTier.name %>"
                          class="member-league-icon">
                      <% } %>

                      <div>
                        <div class="fw-bold"><%= member.name %></div>
                        <div class="text-muted small"><%= member.tag %></div>
                      </div>
                    </div>
                  </td>

                  <td><%= member.clanName %></td>
                  <td><%= member.leagueTier?.name || member.league?.name || "Unranked" %></td>
                  <td><%= member.trophies?.toLocaleString() || 0 %></td>
                </tr>
              <% }) %>
            </tbody>
          </table>
        </div>

      <% } else { %>

        <p class="text-muted mb-0">
          War scoreboard coming back once the war API behaves itself.
        </p>

      <% } %>

    </div>
  </div>

</main>

<%- include("partials/footer") %>